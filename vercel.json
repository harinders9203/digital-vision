{
    "headers": [
        {
            "source": "/admin.html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, max-age=0"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "same-origin"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/admin",
            "destination": "/api/admin"
        },
        {
            "source": "/admin/",
            "destination": "/api/admin"
        }
    ]
}
